# Replace the placeholder values before enabling this site:
# - __RPC_HOSTNAME__        -> rpc.yourdomain.example
# - __SITE_ORIGIN__         -> https://yourname.github.io or your custom Pages domain
# - __TLS_CERT_FULLCHAIN__  -> /etc/letsencrypt/live/rpc.yourdomain.example/fullchain.pem
# - __TLS_CERT_PRIVKEY__    -> /etc/letsencrypt/live/rpc.yourdomain.example/privkey.pem
#
# This file is meant to be installed under /etc/nginx/sites-available/ and
# symlinked into /etc/nginx/sites-enabled/.

map $http_origin $cors_allow_origin {
    default "";
    "__SITE_ORIGIN__" $http_origin;
}

map $http_upgrade $connection_upgrade {
    default upgrade;
    "" close;
}

server {
    listen 80;
    listen [::]:80;
    server_name __RPC_HOSTNAME__;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name __RPC_HOSTNAME__;

    ssl_certificate __TLS_CERT_FULLCHAIN__;
    ssl_certificate_key __TLS_CERT_PRIVKEY__;
    ssl_session_timeout 1d;
    ssl_session_cache shared:UnifiedRPC:10m;
    ssl_session_tickets off;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;

    client_max_body_size 8m;

    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    location = /rpc {
        if ($request_method = OPTIONS) {
            add_header Access-Control-Allow-Origin $cors_allow_origin always;
            add_header Access-Control-Allow-Methods "POST, OPTIONS" always;
            add_header Access-Control-Allow-Headers "Content-Type" always;
            add_header Access-Control-Max-Age 86400 always;
            add_header Content-Length 0;
            add_header Content-Type text/plain;
            return 204;
        }

        proxy_pass http://127.0.0.1:3337/rpc;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;

        add_header Access-Control-Allow-Origin $cors_allow_origin always;
        add_header Access-Control-Allow-Methods "POST, OPTIONS" always;
        add_header Access-Control-Allow-Headers "Content-Type" always;
        add_header Vary "Origin" always;
    }

    location = /ws {
        proxy_pass http://127.0.0.1:3337/ws;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }

    location = /healthz {
        proxy_pass http://127.0.0.1:3337/healthz;
        proxy_set_header Host $host;
        add_header Access-Control-Allow-Origin $cors_allow_origin always;
        add_header Vary "Origin" always;
    }

    location = /readyz {
        proxy_pass http://127.0.0.1:3337/readyz;
        proxy_set_header Host $host;
        add_header Access-Control-Allow-Origin $cors_allow_origin always;
        add_header Vary "Origin" always;
    }

    location /p2p/ {
        proxy_pass http://127.0.0.1:3337/p2p/;
        proxy_set_header Host $host;
        add_header Access-Control-Allow-Origin $cors_allow_origin always;
        add_header Vary "Origin" always;
    }

    location /chain/ {
        proxy_pass http://127.0.0.1:3337/chain/;
        proxy_set_header Host $host;
        add_header Access-Control-Allow-Origin $cors_allow_origin always;
        add_header Vary "Origin" always;
    }

    location /governance/ {
        if ($request_method = OPTIONS) {
            add_header Access-Control-Allow-Origin $cors_allow_origin always;
            add_header Access-Control-Allow-Methods "GET, POST, OPTIONS" always;
            add_header Access-Control-Allow-Headers "Content-Type" always;
            add_header Access-Control-Max-Age 86400 always;
            add_header Content-Length 0;
            add_header Content-Type text/plain;
            return 204;
        }

        proxy_pass http://127.0.0.1:3337/governance/;
        proxy_set_header Host $host;
        add_header Access-Control-Allow-Origin $cors_allow_origin always;
        add_header Access-Control-Allow-Methods "GET, POST, OPTIONS" always;
        add_header Access-Control-Allow-Headers "Content-Type" always;
        add_header Vary "Origin" always;
    }

    location /consensus/ {
        if ($request_method = OPTIONS) {
            add_header Access-Control-Allow-Origin $cors_allow_origin always;
            add_header Access-Control-Allow-Methods "GET, POST, OPTIONS" always;
            add_header Access-Control-Allow-Headers "Content-Type" always;
            add_header Access-Control-Max-Age 86400 always;
            add_header Content-Length 0;
            add_header Content-Type text/plain;
            return 204;
        }

        proxy_pass http://127.0.0.1:3337/consensus/;
        proxy_set_header Host $host;
        add_header Access-Control-Allow-Origin $cors_allow_origin always;
        add_header Access-Control-Allow-Methods "GET, POST, OPTIONS" always;
        add_header Access-Control-Allow-Headers "Content-Type" always;
        add_header Vary "Origin" always;
    }
}
